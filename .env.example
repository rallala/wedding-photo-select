# 이 파일을 복사해서 .env로 저장하고 실제 값을 채우세요. (.env는 .gitignore에 있어 커밋되지 않습니다)
# 실제 값은 Vercel 대시보드 → Settings → Environment Variables 에서 그대로 복사하면 됩니다.

# Supabase 대시보드 → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role 키 — 절대 커밋/공유 금지
SUPABASE_SERVICE_ROLE_KEY=

# 카카오 개발자 콘솔
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# 셀렉룸 접속 코드 "카카오톡으로 보내기" 버튼용 (로그인과는 무관, 없어도 클립보드 복사로 대체됨)
KAKAO_JS_KEY=

# 네이버 개발자 센터
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 로컬 실행 시 옵션
# PORT=3000
# PIN=1234
